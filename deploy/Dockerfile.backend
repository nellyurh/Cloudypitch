FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# OS deps
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Python deps — copy requirements first for cache efficiency
COPY backend/requirements.txt /app/backend/requirements.txt
# Two-stage install dodges a pip-resolver bug where `litellm` appears
# both as a direct URL spec AND as a transitive dep of `emergentintegrations`.
RUN pip install --extra-index-url https://d33sy5i8bnduwe.cloudfront.net/simple/ \
        emergentintegrations==0.1.2 \
 && pip install --extra-index-url https://d33sy5i8bnduwe.cloudfront.net/simple/ \
        --use-deprecated=legacy-resolver \
        -r /app/backend/requirements.txt

# Source
COPY backend /app/backend
WORKDIR /app/backend

EXPOSE 8001

# Default command — API. Worker container overrides with `python worker.py`.
CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8001", "--workers", "2"]
